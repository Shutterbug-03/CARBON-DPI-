{
  "name": "@carbon-dpi/beckn-adapter",
  "version": "1.1.0",
  "description": "Beckn Protocol BPP adapter for Carbon DPI — standalone service + library",
  "main": "./dist/adapter.js",
  "types": "./dist/adapter.d.ts",
  "exports": {
    ".": {
      "types": "./dist/adapter.d.ts",
      "require": "./dist/adapter.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "require": "./dist/server.js"
    },
    "./signing": {
      "types": "./dist/signing.d.ts",
      "require": "./dist/signing.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "dev:watch": "ts-node-dev --respawn --transpile-only src/server.ts",
    "keygen": "ts-node -e \"const { generateKeyPair } = require('./src/signing'); const kp = generateKeyPair(); console.log('BECKN_ED25519_PUBLIC_KEY=' + kp.publicKey); console.log('BECKN_ED25519_PRIVATE_KEY=' + kp.privateKey);\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "carbon-dpi",
    "beckn",
    "beckn-adapter",
    "oncm",
    "climate-verification",
    "mrv",
    "gic",
    "ed25519",
    "open-protocol"
  ],
  "author": "Carbon DPI Contributors",
  "license": "Apache-2.0",
  "dependencies": {
    "express": "^4.19.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.21",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0"
  }
}
