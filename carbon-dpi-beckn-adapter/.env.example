# ─── Carbon DPI Reference Node — Environment Configuration ───────────────────
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
LOG_LEVEL=info         # debug | info | warn | error

# ── Beckn Subscriber Identity ─────────────────────────────────────────────────
# The domain name you registered on registry.becknprotocol.io
BECKN_SUBSCRIBER_ID=carbon-dpi.your-domain.in

# The unique key ID you chose during Beckn registration
BECKN_UNIQUE_KEY_ID=carbon-dpi-key-001

# ── Ed25519 Key Pair (Beckn Signature signing) ─────────────────────────────────
# Generate once with: npm run keygen
# Register the PUBLIC key on registry.becknprotocol.io
# Keep the PRIVATE key secret — never commit it
BECKN_ED25519_PUBLIC_KEY=
BECKN_ED25519_PRIVATE_KEY=

# ── HMAC Shared Secret (fallback / dev mode) ───────────────────────────────────
# Used for x-carbon-dpi-signature header when Ed25519 keys are not configured
BECKN_SHARED_SECRET=change-me-in-production

# ── Signature Verification ─────────────────────────────────────────────────────
# Set to true in production to verify Authorization: Signature headers
BECKN_VERIFY_INCOMING=false

# ── Carbon DPI Base URL ────────────────────────────────────────────────────────
# The public URL where this node is reachable (for GIC verification links)
CARBON_DPI_BASE_URL=https://verify.greenpe.in
