# ─── Carbon DPI Reference Node — Environment Configuration ───────────────────
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info          # debug | info | warn | error

# ── Beckn Subscriber Identity ─────────────────────────────────────────────────
BECKN_SUBSCRIBER_ID=carbon-dpi.your-domain.in
BECKN_UNIQUE_KEY_ID=carbon-dpi-key-001

# ── Ed25519 Key Pair ──────────────────────────────────────────────────────────
# Generate with: npm run keygen
# Register the PUBLIC key on registry.becknprotocol.io
BECKN_ED25519_PUBLIC_KEY=
BECKN_ED25519_PRIVATE_KEY=

# ── HMAC Shared Secret (dev fallback) ─────────────────────────────────────────
BECKN_SHARED_SECRET=change-me-in-production

# ── Signature Verification ─────────────────────────────────────────────────────
BECKN_VERIFY_INCOMING=false

# ── Carbon DPI Base URL ────────────────────────────────────────────────────────
CARBON_DPI_BASE_URL=https://verify.greenpe.in
