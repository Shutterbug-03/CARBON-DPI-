{
  "name": "@carbon-dpi/event-bus",
  "version": "1.0.0",
  "description": "High-throughput telemetry ingestion and batching service for Carbon DPI.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "ts-node-dev --respawn --transpile-only src/index.ts",
    "type-check": "tsc --noEmit",
    "test": "jest --forceExit"
  },
  "dependencies": {
    "@carbon-dpi/beckn-adapter": "file:../carbon-dpi-beckn-adapter",
