# ─── Carbon DPI Event Bus — Environment Configuration ──────────────────────────
#
# Copy this file to .env and fill in your values.
#
# ─────────────────────────────────────────────────────────────────────────────

PORT=3004
NODE_ENV=development
LOG_LEVEL=info

# The Beckn Reference Node (BPP) endpoints
REFERENCE_NODE_URL=http://localhost:3099

# The Trust Registry for CIH lookups (optional if Event Bus computes CIH)
# TRUST_REGISTRY_URL=http://localhost:3003

BATCH_INTERVAL_MS=5000
