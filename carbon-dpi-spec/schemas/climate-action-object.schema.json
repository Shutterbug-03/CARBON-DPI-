{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClimateActionObject",
  "description": "Carbon DPI Protocol — Foundational data structure representing any measurable climate activity. Every climate action in the Carbon DPI network is represented as a ClimateActionObject.",
  "type": "object",
  "required": [
    "activity_id",
    "activity_type",
    "asset_id",
    "owner_cih",
    "location",
    "timestamp_utc",
    "data_source",
    "methodology_id",
    "verification_status",
    "schema_version"
  ],
  "properties": {
    "activity_id": {
      "type": "string",
      "description": "Globally unique identifier for this climate activity",
      "pattern": "^ACT-[0-9]{4}-[A-Z]{2}-[A-Z]{3}-[0-9]{4}-Q[1-4]$",
      "examples": ["ACT-2024-GJ-SOL-0442-Q3"]
    },
    "activity_type": {
      "type": "string",
      "enum": [
        "solar_pv_rooftop",
        "solar_pv_utility",
        "ev_fleet_commercial",
        "ev_individual",
        "biogas",
        "industrial_efficiency_pat",
        "afforestation",
        "mangrove",
        "agricultural_solar_pump",
        "waste_methane",
        "fuel_switch_lng",
        "cbg",
        "building_efficiency",
        "wind_onshore",
        "wind_offshore"
      ],
      "description": "CDIF asset type taxonomy identifier"
    },
    "asset_id": {
      "type": "string",
      "description": "Unique identifier for the physical asset generating or avoiding emissions"
    },
    "owner_cih": {
      "type": "string",
      "description": "Composite Identity Hash — cryptographically binds the asset owner's verified identity to this activity",
      "minLength": 64,
      "maxLength": 64
    },
    "location": {
      "type": "object",
      "required": ["gps", "country"],
      "properties": {
        "gps": {
          "type": "string",
          "description": "GPS coordinates as 'latitude,longitude'",
          "pattern": "^-?[0-9]+\\.?[0-9]*,-?[0-9]+\\.?[0-9]*$"
        },
        "area_code": {
          "type": "string",
          "description": "PIN code or area code"
        },
        "city": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "code": { "type": "string" }
          }
        },
        "country": {
          "type": "object",
          "required": ["code"],
          "properties": {
            "name": { "type": "string" },
            "code": { "type": "string", "pattern": "^[A-Z]{3}$" }
          }
        }
      }
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the climate action measurement"
    },
    "data_source": {
      "type": "object",
      "required": ["source_type", "source_id"],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "iot_inverter",
            "iot_smart_meter",
            "iot_scada",
            "iot_telematics",
            "satellite_feed",
            "erp_extract",
            "discom_api",
            "manual_upload"
          ],
          "description": "Type of data source providing the measurement"
        },
        "source_id": {
          "type": "string",
          "description": "Unique identifier for the data source device or system"
        },
        "device_fingerprint": {
          "type": "string",
          "description": "Hardware fingerprint of the IoT device (MAC, serial, or firmware hash)"
        },
        "data_signature": {
          "type": "string",
          "description": "Ed25519 or HMAC signature from the device proving data authenticity"
        }
      }
    },
    "methodology_id": {
      "type": "string",
      "description": "Carbon DPI methodology registry identifier",
      "pattern": "^CUPI-METH-[0-9]{3}$",
      "examples": ["CUPI-METH-001"]
    },
    "verification_status": {
      "type": "string",
      "enum": ["pending", "in_progress", "verified", "rejected", "disputed"],
      "description": "Current verification status of this climate action"
    },
    "schema_version": {
      "type": "string",
      "description": "Carbon DPI schema version for backward compatibility",
      "examples": ["1.0.0"]
    }
  },
  "additionalProperties": false
}
