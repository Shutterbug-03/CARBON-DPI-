{
  "name": "@carbon-dpi/registry",
  "version": "1.0.0",
  "description": "Trust Registry Service for Carbon DPI Protocol",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "ts-node-dev --respawn --transpile-only src/index.ts",
    "type-check": "tsc --noEmit",
    "use:postgres": "cp prisma/schema.postgres.prisma prisma/schema.prisma && npx prisma generate",
    "use:sqlite": "git checkout prisma/schema.prisma && npx prisma generate",
    "test": "jest --forceExit"
  },
  "keywords": [
    "carbon-dpi",
    "registry",
    "trust",
    "device",
    "verifier",
    "methodology"
  ],
  "author": "Carbon DPI Contributors",
  "license": "Apache-2.0",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/client": "6.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.7",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "pino-pretty": "^13.1.3",
    "prisma": "6.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
