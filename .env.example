# ──────────────────────────────────────────────────────────────────────────────
# Carbon DPI — Production Environment Configuration
#
# Copy this file to .env and fill in all values before deploying.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── TLS / Domain ──────────────────────────────────────────────────────────────
# Your public domain (Caddy will auto-provision Let's Encrypt certs)
DOMAIN=yourdomain.com
ACME_EMAIL=you@yourdomain.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins (no trailing slashes)
# Example: https://app.yourdomain.com,https://dashboard.yourdomain.com
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com

# ── Admin ─────────────────────────────────────────────────────────────────────
# Admin API key — used for device registration and GIC revocation.
# Use a strong random secret: openssl rand -hex 32
REGISTRY_ADMIN_KEY=CHANGE_ME_USE_STRONG_SECRET

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Beckn Ed25519 Signing Keys ────────────────────────────────────────────────
# Generate with: cd carbon-dpi-reference-node && npm run keygen
# The private key is used to sign outgoing Beckn callbacks and W3C VCs.
# The public key is registered in the Trust Registry for verification.
BECKN_ED25519_PRIVATE_KEY=BASE64_ENCODED_PKCS8_DER_PRIVATE_KEY
BECKN_ED25519_PUBLIC_KEY=BASE64_ENCODED_SPKI_DER_PUBLIC_KEY

# ── Beckn Gateway Signing Key ─────────────────────────────────────────────────
# Separate Ed25519 key for the Gateway to sign outgoing multicast requests.
BECKN_GATEWAY_PRIVATE_KEY=BASE64_ENCODED_PKCS8_DER_PRIVATE_KEY

# ── BAP Public Key ────────────────────────────────────────────────────────────
# The public key of the BAP (Event Bus) for verifying incoming Beckn requests.
# If not set, the node will try to fetch it dynamically from the Trust Registry.
BECKN_BAP_PUBLIC_KEY=

# ── Beckn Subscriber IDs ──────────────────────────────────────────────────────
BECKN_SUBSCRIBER_ID=carbon-dpi.yourdomain.com
BECKN_GATEWAY_SUBSCRIBER_ID=gateway.carbon-dpi.yourdomain.com
BECKN_UNIQUE_KEY_ID=key-1

# ── Service URLs (internal docker networking) ─────────────────────────────────
REGISTRY_URL=http://registry:3003
REFERENCE_NODE_URL=http://reference-node:3001
TRUST_REGISTRY_URL=http://registry:3003
BECKN_GATEWAY_URL=http://gateway:3005
BAP_URI=https://bus.yourdomain.com

# ── GIC Public Verification URL ───────────────────────────────────────────────
# This URL appears in the W3C VC as the public verification endpoint.
GIC_BASE_URL=https://verify.yourdomain.com/v1

# ── Internal mTLS (optional) ──────────────────────────────────────────────────
# Set to true to enable mutual TLS between services.
# Run ./gen-certs.sh first to generate development certificates.
# For production, use proper PKI (HashiCorp Vault, AWS ACM PCA, etc.)
INTERNAL_TLS=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
